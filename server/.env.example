NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/krushak_pwa?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_secure_random_secret_min_32_chars
# For Render production: set to your frontend static site URL
#   e.g. CLIENT_ORIGIN=https://krushak-client.onrender.com
# For local dev: CLIENT_ORIGIN=http://localhost:5173
# To allow multiple origins: CLIENT_ORIGIN=http://localhost:5173,https://krushak-client.onrender.com
CLIENT_ORIGIN=http://localhost:5173
MANDI_API_KEY=your_data_gov_mandi_key
GNEWS_API_KEY=your_gnews_key
GNEWS_COUNTRY=in
NEWSDATA_API_KEY=your_newsdata_key
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro
